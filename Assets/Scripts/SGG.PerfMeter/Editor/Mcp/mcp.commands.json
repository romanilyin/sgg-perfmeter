      "timeout_ms": 10000,
      "tags": ["perfmeter", "session"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.session.export",
      "title": "Export PerfMeter session",
      "description": "Export the current SGG PerfMeter session to a project-local JSON or CSV file.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.SessionExport",
      "risk": "write",
      "idempotency": "unsafe",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "session", "export"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "format": { "type": "string", "enum": ["json", "csv"] }
        },
        "required": ["path", "format"],
        "additionalProperties": false
      }
    }
