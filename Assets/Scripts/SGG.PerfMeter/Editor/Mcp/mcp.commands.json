      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverdrawHeatmapSet",
      "risk": "write",
      "idempotency": "idempotent",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "overdraw", "heatmap"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "visible": { "type": "boolean" }
        },
        "required": ["visible"],
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.session.start",
      "title": "Start PerfMeter session recording",
      "description": "Start bounded SGG PerfMeter session recording with optional warmup, scene-load handling, sample interval, and max sample overrides.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.SessionStart",
      "risk": "write",
      "idempotency": "unsafe",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "session"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "warmup_frames": { "type": "integer", "minimum": 0 },
          "warmup_seconds": { "type": "number", "minimum": 0 },
          "sample_interval_seconds": { "type": "number", "exclusiveMinimum": 0 },
          "max_samples": { "type": "integer", "minimum": 1 },
          "reset_on_scene_load": { "type": "boolean" },
          "scene_load_ignore_frames": { "type": "integer", "minimum": 0 },
          "scene_load_ignore_seconds": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.session.stop",
      "title": "Stop PerfMeter session recording",
      "description": "Stop the active SGG PerfMeter session recording and return its summary.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.SessionStop",
      "risk": "write",
      "idempotency": "idempotent",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "session"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
