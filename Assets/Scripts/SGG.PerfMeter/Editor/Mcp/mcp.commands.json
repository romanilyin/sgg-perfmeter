    {
      "id": "perfmeter.overlay.set",
      "title": "Set PerfMeter overlay",
      "description": "Show or hide the SGG PerfMeter overlay and optionally set its screen corner, display mode, and target FPS.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverlaySet",
      "risk": "write",
      "idempotency": "idempotent",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "overlay"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "visible": { "type": "boolean" },
          "corner": {
            "type": "string",
            "enum": ["TopLeft", "TopRight", "BottomLeft", "BottomRight"]
          },
          "mode": {
            "type": "string",
            "enum": ["FpsOnly", "TextCompact", "Graphs", "Full"]
          },
          "target_fps": {
            "type": "integer",
            "enum": [15, 30, 60, 90, 120, 144, 240]
          }
        },
        "required": ["visible"],
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.overdraw.start",
      "title": "Start PerfMeter overdraw measurement",
      "description": "Request a bounded SGG PerfMeter overdraw measurement.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverdrawStart",
      "risk": "write",
      "idempotency": "unsafe",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "overdraw"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "frame_count": { "type": "integer", "minimum": 1, "maximum": 600 }
        },
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.overdraw.cancel",
      "title": "Cancel PerfMeter overdraw measurement",
      "description": "Cancel the current SGG PerfMeter overdraw measurement.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverdrawCancel",
      "risk": "write",
      "idempotency": "idempotent",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "overdraw"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.overdraw.heatmap.set",
      "title": "Set PerfMeter overdraw heatmap",
      "description": "Show or hide the SGG PerfMeter visual overdraw heatmap.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverdrawHeatmapSet",
      "risk": "write",
      "idempotency": "idempotent",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "overdraw", "heatmap"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "visible": { "type": "boolean" }
        },
        "required": ["visible"],
        "additionalProperties": false
      }
    }
