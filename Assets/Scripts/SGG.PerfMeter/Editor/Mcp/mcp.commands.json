    {
      "id": "perfmeter.camera.snapshot",
      "title": "PerfMeter camera snapshot",
      "description": "Read camera transform, projection, and URP camera settings for reproducible performance captures.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.CameraSnapshot",
      "risk": "read",
      "idempotency": "safe",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "camera", "snapshot"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "enum": ["Auto", "MainCamera", "NameFilter", "FirstGameCamera"]
          },
          "camera_name_filter": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.overlay.set",
      "title": "Set PerfMeter overlay",
      "description": "Show or hide the SGG PerfMeter overlay and optionally set its preset, modules, screen corner, display mode, and target FPS.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverlaySet",
      "risk": "write",
      "idempotency": "idempotent",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "overlay"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "visible": { "type": "boolean" },
          "preset": {
            "type": "string",
            "enum": ["Custom", "Minimal", "Timing", "Rendering", "Memory", "Overdraw", "FullDiagnostics", "AgentDebug"]
          },
          "corner": {
            "type": "string",
            "enum": ["TopLeft", "TopRight", "BottomLeft", "BottomRight"]
          },
          "mode": {
            "type": "string",
            "enum": ["FpsOnly", "TextCompact", "Graphs", "Full"]
          },
          "target_fps": {
            "type": "integer",
            "enum": [15, 30, 60, 90, 120, 144, 240]
          },
          "modules": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["None", "All", "Fps", "Timing", "Graphs", "Rendering", "SrpBatcher", "Brg", "Uploads", "Memory", "Gc", "GpuMemory", "Overdraw", "Heatmap", "Warnings"]
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "required": ["visible"],
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.overdraw.start",
      "title": "Start PerfMeter overdraw measurement",
      "description": "Request a bounded SGG PerfMeter overdraw measurement.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverdrawStart",
      "risk": "write",
      "idempotency": "unsafe",
      "timeout_ms": 10000,
      "tags": ["perfmeter", "overdraw"],
      "capability": "perfmeter",
      "schema": {
        "type": "object",
        "properties": {
          "frame_count": { "type": "integer", "minimum": 1, "maximum": 600 }
        },
        "additionalProperties": false
      }
    },
    {
      "id": "perfmeter.overdraw.cancel",
      "title": "Cancel PerfMeter overdraw measurement",
      "description": "Cancel the current SGG PerfMeter overdraw measurement.",
      "handler": "SGG.PerfMeter.Editor.Mcp.PerfMeterMcpCommands.OverdrawCancel",
      "risk": "write",
